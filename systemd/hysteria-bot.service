[Unit]
Description=Hysteria 2 Telegram Admin Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=hysteria-bot
Group=hysteria-bot
WorkingDirectory=/opt/hysteria-bot
EnvironmentFile=/opt/hysteria-bot/.env
ExecStart=/usr/bin/node /opt/hysteria-bot/dist/app.js
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/hysteria-bot/data

[Install]
WantedBy=multi-user.target
